class Solution {
    public boolean isValidSudoku(char[][] board) {
        int n = 9;
        for (int i = 0; i < 9; i++) {
            if (!rowValidate(board, i, n)) return false;
            if (!colValidate(board, i, n)) return false;
        }
        for (int row = 0; row < 9; row += 3) {
            for (int col = 0; col < 9; col += 3) {
                if (!Cross3Validate(board, row, col)) {
                    return false;
                }
            }
        }
        return true;
    }
    public boolean rowValidate(char[][] board, int k, int n) {
        for (int i = 0; i < n; i++) {
            if (board[k][i] == '.') continue; 
            char current = board[k][i];
            for (int j = i + 1; j < n; j++) {
                if (current == board[k][j]) {
                    return false;
                }
            }
        }
        return true;
    }
    public boolean colValidate(char[][] board, int k, int n) {
        for (int i = 0; i < n; i++) {
            if (board[i][k] == '.') continue; 
            char current = board[i][k];
            for (int j = i + 1; j < n; j++) {
                if (current == board[j][k]) {
                    return false;
                }
            }
        }
        return true;
    }
    public boolean Cross3Validate(char[][] board, int startRow, int startCol) {
        for (int i = 0; i < 9; i++) {
            int r1 = startRow + i / 3;
            int c1 = startCol + i % 3;
            
            if (board[r1][c1] == '.') continue;
            
            for (int j = i + 1; j < 9; j++) {
                int r2 = startRow + j / 3;
                int c2 = startCol + j % 3;
                if (board[r1][c1] == board[r2][c2]) {
                    return false;
                }
            }
        }
        return true;
    }
}
