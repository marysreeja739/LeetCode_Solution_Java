/**
 * @param {integer} init
 * @return { increment: Function, decrement: Function, reset: Function }
 */
var createCounter = function(init) {
    let n = init;

    return {
        increment: function() {
            return ++n;
        },
        decrement: function() {
            return --n;
        },
        reset: function() {
            n = init;
            return n;
        }
    };
};
