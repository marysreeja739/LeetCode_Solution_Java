import java.util.PriorityQueue;

class KthLargest {
    private PriorityQueue<Integer> minHeap;
    private int k;

    public KthLargest(int k, int[] nums) {
        this.k = k;
        this.minHeap = new PriorityQueue<>();
        
        // Add all existing scores to our stream
        for (int score : nums) {
            add(score);
        }
    }
    
    public int add(int val) {
        // 1. Add the new score to the heap
        minHeap.offer(val);
        
        // 2. If we have more than k scores, throw away the smallest one.
        // The heap automatically keeps the smallest at the top (peek).
        if (minHeap.size() > k) {
            minHeap.poll(); 
        }
        
        // 3. The top of the heap is now the kth largest score.
        return minHeap.peek();
    }
}


