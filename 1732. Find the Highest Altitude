class Solution {
    public int largestAltitude(int[] gain) {
        int max_height = 0;
        int curr_height=0;
        for(int i=0;i<gain.length;i++){
            curr_height += gain[i];
            if(curr_height> max_height) max_height = curr_height;
        }
        return max_height;
    }
}
