class MyStack {
    public int[] arr=new int[10];
    public int top;

    public MyStack() {
        top=0;
    }
    
    public void push(int x) {
        if (top == arr.length) {
            throw new IllegalStateException("Stack Overflow: Stack is full.");
        }
        arr[top] = x;
        top++; 
    }

    public int pop() {
        if (empty()) {
            throw new IllegalStateException("Stack Underflow: Stack is empty.");
        }
        top--;
        return arr[top]; 
    }

    public int top() {
        if (empty()) {
            
            throw new IllegalStateException("Stack is empty: No top element.");
        }
        return arr[top - 1]; 
    }

    public boolean empty() {
        return top == 0; 
    }
}

