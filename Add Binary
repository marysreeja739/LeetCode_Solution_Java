class Solution {
    public String addBinary(String a, String b) {
        StringBuilder sb = new StringBuilder();
        int i = a.length() - 1;
        int j = b.length() - 1;
        int carry = 0;

        // Loop as long as there are characters in either string or a carry remains
        while (i >= 0 || j >= 0 || carry > 0) {
            int sum = carry;
            
            if (i >= 0) {
                sum += a.charAt(i) - '0'; // Convert char to int
                i--;
            }
            if (j >= 0) {
                sum += b.charAt(j) - '0';
                j--;
            }

            // In binary: sum % 2 gives the current bit, sum / 2 gives the carry
            sb.append(sum % 2);
            carry = sum / 2;
        }

        // Since we appended from right to left, we must reverse the result
        return sb.reverse().toString();
    }
}
