char * mergeAlternately(char * word1, char * word2){
    int len1 = strlen(word1);
    int len2 = strlen(word2);
    int n = len1+len2;
    char* merged = malloc((n+1)*sizeof(char));
    int i=0,j=0,k=0;
    while(i<len1 || j<len2)
    {
        if(i<len1)
        {
            merged[k++] = word1[i++];
        }
        if(j<len2)
        {
            merged[k++] = word2[j++];
        }
    }
    merged[k] = '\0';
    return merged;

}
