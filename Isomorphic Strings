bool isIsomorphic(char* s, char* t)
{
    int s_size=strlen(s);
    int t_size=strlen(t);
    if(s_size==t_size)
    {
        for(int i=0;i<s_size;i++)
        {
            for(int j=i+1;j<s_size;j++)
            {
            if(((s[i]==s[j])&&(t[i]!=t[j]))||((s[i]!=s[j])&&(t[i]==t[j])))
            {
                return false;
            }
            }
        }
    }
    return true;
}
