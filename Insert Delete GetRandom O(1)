import java.util.*;

class RandomizedSet {
    private ArrayList<Integer> list;
    private HashMap<Integer, Integer> map;
    private Random rand;

    public RandomizedSet() {
        list = new ArrayList<>();
        map = new HashMap<>();
        rand = new Random();
    }
    
    public boolean insert(int val) {
        if (map.containsKey(val)) return false;
        
        // Add to map: key is value, value is its current index in list
        map.put(val, list.size());
        list.add(val);
        return true;
    }
    
    public boolean remove(int val) {
        if (!map.containsKey(val)) return false;
        
        // 1. Get the index of the element to remove
        int indexToRemove = map.get(val);
        int lastElement = list.get(list.size() - 1);
        
        // 2. Move the last element to the spot of the element we are removing
        list.set(indexToRemove, lastElement);
        map.put(lastElement, indexToRemove);
        
        // 3. Remove the last element (no shifting needed!)
        list.remove(list.size() - 1);
        map.remove(val);
        
        return true;
    }
    
    public int getRandom() {
        // Pick a random index from 0 to list.size() - 1
        return list.get(rand.nextInt(list.size()));
    }
}


