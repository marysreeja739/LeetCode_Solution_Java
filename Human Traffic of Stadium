# Write your MySQL query statement below
WITH ConsecutiveGroups AS (
    SELECT *,
           -- The magic trick: id minus a continuous row number
           -- stays constant for consecutive ids.
           id - ROW_NUMBER() OVER (ORDER BY id) AS grp
    FROM Stadium
    WHERE people >= 100
),
GroupCounts AS (
    SELECT *,
           COUNT(*) OVER (PARTITION BY grp) AS count_in_group
    FROM ConsecutiveGroups
)
SELECT id, visit_date, people
FROM GroupCounts
WHERE count_in_group >= 3
ORDER BY visit_date;
